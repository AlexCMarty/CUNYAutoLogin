{
  "manifest_version": 2,
  "name": "CUNYAutoLogin",
  "version": "0.0.0",

  "description": "Automatically logs you in to CUNYFirst.",

  "icons": {
    "48": "icons/red_square.png"
  },

  "permissions": ["activeTab"],

  "browser_action": {
    "default_icon": "icons/red_square.png",
    "default_title": "Configure",
    "default_popup": "popup/index.html"
  },

  "web_accessible_resources": [
  ],

  "content_scripts": [
    {
      "matches": ["https://ssologin.cuny.edu/*"],
      "js": ["login.js"]
    }
  ]
}