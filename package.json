{
  "name": "cuny-sso-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build && vite build -c vite.content.config.ts",
    "watch": "vite build --watch",
    "build:content": "vite build -c vite.content.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/webextension-polyfill": "^0.12.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-static-copy": "^2.2.0",
    "@types/totp-generator": "^0.0.8"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0",
    "totp-generator": "^2.0.1",
    "neverthrow": "^8.2.0"
  }
}
