{
  "name": "cunyautologin",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && vite build && vite build -c vite.content.config.ts",
    "build:dev": "tsc --noEmit && vite build --mode development && vite build -c vite.content.config.ts --mode development",
    "build:e2e": "cross-env E2E_MANIFEST=1 npm run build:dev",
    "watch": "vite build --watch --mode development",
    "build:content": "vite build -c vite.content.config.ts",
    "typecheck": "tsc --noEmit",
    "test:e2e": "npm run build:e2e && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "cross-env": "^7.0.3",
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/webextension-polyfill": "^0.12.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vite-plugin-static-copy": "^2.2.0",
    "@types/totp-generator": "^0.0.8"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0",
    "totp-generator": "^2.0.1",
    "neverthrow": "^8.2.0"
  }
}
